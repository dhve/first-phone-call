# Host39 server environment. Copy to server/.env:
#
#   cp server/.env.example server/.env
#
# Both `npm run dev -w server` and `npm run migrate` load this file via
# --env-file=.env, so it must exist for local (non-Docker) development.
# Every variable read by server/src/config.ts is listed; commented lines
# show the built-in defaults. See the root README for the full table.

# Required. No default; the server exits if missing.
# Docker Postgres (docker compose up db -d) listens on host port 5434:
DATABASE_URL=postgresql://host39:host39-local@localhost:5434/host39
# Local Postgres alternative:
# DATABASE_URL=postgresql://youruser@localhost:5432/host39

# Optional in development (a dev default is used). Required in production:
# at least 16 characters and not the shipped dev default.
JWT_SECRET=dev-secret-0123456789abcdef

# Base URL public cards are served from. Baked into published card URLs,
# _meta.publicUrl, the catalog, and the derived relay WS URL. Signed card
# uploads validate card.url against this value, so it must match what the
# phone uses as its public base URL.
PUBLIC_BASE_URL=http://localhost:3010

# NODE_ENV=development
# PORT=3010
# DB_MAX_CONNECTIONS=10
# JWT_EXPIRES_IN=7d
# FRONTEND_URL=http://localhost:3002

# Relay (device WebSocket)
# RELAY_PUBLIC_URL defaults to PUBLIC_BASE_URL with http->ws plus /relay.
# RELAY_PUBLIC_URL=ws://localhost:3010/relay
# RELAY_TOKEN_TTL_SECONDS=60
# RELAY_HEARTBEAT_INTERVAL_MS=30000
# RELAY_HEARTBEAT_MAX_MISSED=2
# RELAY_WS_MAX_PAYLOAD_BYTES=262144

# A2A runtime (phone-hosted agents)
# RUNTIME_TIMEOUT_MS=120000
# RUNTIME_MAX_REQUEST_BYTES=16384
# RUNTIME_RATE_LIMIT_MAX=30
# RUNTIME_RATE_LIMIT_WINDOW_MS=60000
