From: dhve <v3dhkrishnan@gmail.com>
Date: Sun, 19 Jul 2026 13:40:31 -0400
Subject: [PATCH] feat: personal registrations require URN email match and
 activate on email verification

---
 server/src/db/queries/organizations.ts        |  17 +-
 server/src/routes/index-records.ts            |   6 +-
 server/src/routes/orgs.ts                     |  12 ++
 .../integration/personal-registration.test.ts | 153 ++++++++++++++++++
 4 files changed, 181 insertions(+), 7 deletions(-)
 create mode 100644 server/tests/integration/personal-registration.test.ts

diff --git a/server/src/db/queries/organizations.ts b/server/src/db/queries/organizations.ts
index 6188494..cbc3865 100644
--- a/server/src/db/queries/organizations.ts
+++ b/server/src/db/queries/organizations.ts
@@ -180,8 +180,10 @@ export async function insertOrganization(params: InsertOrgParams): Promise<Organ
  * Changing the `domain` invalidates the ownership proof: the prior verification
  * was for the old domain, so domain_verified and any pending challenge are
  * cleared, and an active org reverts to 'pending' until the new domain is
- * re-verified. This keeps the invariant "active ⇒ domain_verified" — otherwise
- * an admin could verify one domain then silently swap in another they don't own.
+ * re-verified. This keeps the invariant "active with a domain implies
+ * domain_verified" (personal orgs have no domain and activate via verified
+ * email instead) — otherwise an admin could verify one domain then silently
+ * swap in another they don't own.
  *
  * Returns null if org_id not found.
  */
@@ -227,9 +229,11 @@ export async function updateOrganization(
 /**
  * Marks an organization's contact email as verified and clears the token.
  *
- * This proves contact-email reachability only — it does NOT activate the org.
- * Activation is gated on domain ownership (see markDomainVerified). Returns
- * null if no org matched the token or the token has expired.
+ * For domain-based registrations this proves contact-email reachability only;
+ * activation stays gated on domain ownership (see markDomainVerified). For
+ * personal registrations (no domain), the verified email IS the identity the
+ * URN is derived from, so a pending org activates here. Returns null if no
+ * org matched the token or the token has expired.
  */
 export async function markEmailVerifiedByToken(token: string): Promise<Organization | null> {
   const sql = getSql();
@@ -238,6 +242,9 @@ export async function markEmailVerifiedByToken(token: string): Promise<Organizat
       email_verified           = TRUE,
       verify_token             = NULL,
       verify_token_expires_at  = NULL,
+      status                   = CASE
+        WHEN domain IS NULL AND status = 'pending' THEN 'active'
+        ELSE status END,
       updated_at               = NOW()
     WHERE verify_token = ${token}
       AND verify_token_expires_at > NOW()
diff --git a/server/src/routes/index-records.ts b/server/src/routes/index-records.ts
index 8d21e9a..ecb46f9 100644
--- a/server/src/routes/index-records.ts
+++ b/server/src/routes/index-records.ts
@@ -8,7 +8,9 @@ import { apiErrorSchema } from '../types/api/common.js';
